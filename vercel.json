{
  "framework": "vite",
  "functions": {
    "api/analyze.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    {
      "source": "/((?!api/|assets/|fonts/|favicon\\.svg|icons\\.svg).*)",
      "destination": "/index.html"
    }
  ]
}
